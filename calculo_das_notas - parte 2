soma_total_sala = 0
num_alunos = 50
num_notas = 4 

for aluno in range(1, num_alunos + 1):
    soma_nota_aluno = 0
    print(f"\n Notas do aluno {aluno} ")

    for n in range (1, num_notas + 1):
        while True:
           nota = float(input(f"Digite a nota {n}: "))
           if 0 <= nota <= 10:
              break
           else:
              print("Nota invalida digite uma nota entre 0 e 10 ")
        soma_nota_aluno += nota
    media_individual = soma_nota_aluno/num_notas
    print(f"Media do aluno {aluno}: {media_individual:.2f} ")

    if media_individual >= 7.0 :
      print("Você está aprovado, parabens ")
    else:
      print("Você está reprovado, melhore ")

    soma_total_sala += media_individual
media_sala = soma_total_sala/num_alunos  
print("-" * 30)
print(f"Media geral da sala: {media_sala:.2f} ")
print("-" * 30)
